# ═══════════════════════════════════════════════════════════════════
# NCLEX Trainer v5 — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────
# For local Docker Compose, these match docker-compose.yml defaults.
# For Railway, these are auto-injected from the PostgreSQL plugin.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nclex
SPRING_DATASOURCE_USERNAME=nclex
SPRING_DATASOURCE_PASSWORD=nclex_dev_password

# ── JWT Authentication ────────────────────────────────────────────
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters

# ── Claude AI API ─────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here

# Models per service
# Question Generation + Voice Assistant → Sonnet
CLAUDE_MODEL_SONNET=claude-sonnet-4-20250514
# Offline Bank Generation (NGN Cases) → Haiku
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001

# ── Spring Profile ────────────────────────────────────────────────
# Options: dev, prod
SPRING_PROFILES_ACTIVE=dev

# ── Server Port ───────────────────────────────────────────────────
# Railway auto-assigns PORT. Locally, backend uses 8080.
SERVER_PORT=8080

# ── Cache Refresh Schedule ────────────────────────────────────────
# Cron expression for content cache refresh (default: 3 AM daily)
# NCLEX_CACHE_REFRESH_CRON=0 0 3 * * *

# ── Readiness Snapshot Schedule ───────────────────────────────────
# Cron expression for daily readiness snapshots (default: 4 AM)
# NCLEX_SNAPSHOT_CRON=0 0 4 * * *

# ── Rate Limiting ─────────────────────────────────────────────────
# Requests per minute per user (default: 20)
# RATE_LIMIT_RPM=20

# ── Logging ───────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARN, ERROR
# LOGGING_LEVEL_COM_NCLEX=INFO
